# 复制此文件为 .env 并填入真实值

DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=30

# ═══════════════════════════════════════════
#  检测后端: replicate_omniparser | local_omniparser
# ═══════════════════════════════════════════
DETECTOR_BACKEND=local_omniparser

# OmniParser GPU API 地址 (校园网 GPU 服务器 :9800)
# 注意: 这是 OmniParser 推理服务，不是 A 端后端!
# 详见 项目文档/B端-OmniParser-GPU-API部署文档.md
OMNIPARSER_LOCAL_URL=http://127.0.0.1:9800
OMNIPARSER_LOCAL_TIMEOUT=60       # GPU 模式 60s 足够；CPU fallback 需 360
OMNIPARSER_LOCAL_MAX_SIDE=3200    # A800 80GB 显存可以处理大图

REPLICATE_API_TOKEN=your-replicate-api-token-here
OMNIPARSER_BOX_THRESHOLD=0.05
OMNIPARSER_IOU_THRESHOLD=0.1
OMNIPARSER_IMGSZ=640
OMNIPARSER_MAX_ELEMENTS=80
OMNIPARSER_MIN_AREA=100
OMNIPARSER_TIMEOUT=60
ALLOW_DETECTOR_FALLBACK=false
REQUIRE_IMAGE=true

HAJIMI_DEMO_KEY=hajimi-demo-2026
HAJIMI_HOST=0.0.0.0
HAJIMI_PORT=8010
HAJIMI_DEBUG=true

USE_REAL_LLM=true
STRICT_FINGERPRINT=false
